generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CaseStatus {
  OPEN
  UNDER_REVIEW
  RECOMMENDED
  CLOSED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Individual {
  id          String              @id
  fullName    String
  email       String              @unique
  phoneNumber String
  countryCode String
  etaRecords  ETARecord[]
  cases       ImmigrationCase[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ETARecord {
  id           String     @id
  individualId String
  etaNumber    String     @unique
  expiresAt    DateTime

  individual   Individual @relation(fields: [individualId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([individualId])
  @@index([expiresAt])
}

model ImmigrationCase {
  id                String           @id
  individualId      String
  reason            String
  assignedOfficerId String
  status            CaseStatus       @default(OPEN)
  riskLevel         RiskLevel
  createdAt         DateTime
  updatedAt         DateTime         @updatedAt

  individual        Individual       @relation(fields: [individualId], references: [id], onDelete: Restrict)
  recommendations   Recommendation[]

  @@index([individualId])
  @@index([assignedOfficerId])
  @@index([status])
}

model Recommendation {
  id              String          @id
  caseId          String
  authorOfficerId String
  summary         String
  createdAt       DateTime

  immigrationCase ImmigrationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}
