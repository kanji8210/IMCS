generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CaseStatus {
  OPEN
  UNDER_REVIEW
  RECOMMENDED
  CLOSED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ViolationType {
  // Temporal (Status & Duration Violations)
  ETA_OVERSTAY
  EXPIRED_PERMIT
  BREACH_OF_CONDITIONS

  // Integrity (Documentary & Identity Violations)
  DOCUMENT_FORGERY
  MATERIAL_MISREPRESENTATION
  FAILURE_TO_NOTIFY

  // Regulatory (Compliance & Administrative Violations)
  FAILURE_TO_REGISTER
  ILLEGAL_EMPLOYMENT
  ILLEGAL_HIRING
  DOCUMENT_REJECTION_FOLLOWUP

  // Security (Security & Public Interest Violations)
  PROHIBITED_IMMIGRANT
  CRIMINAL_CONVICTION
  THREAT_TO_NATIONAL_SECURITY
}

enum ViolationDomain {
  TEMPORAL
  INTEGRITY
  REGULATORY
  SECURITY
}

enum ViolationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ViolationStatus {
  REPORTED
  UNDER_REVIEW
  ESCALATED
  RESOLVED
  DISMISSED
}

model Individual {
  id          String              @id
  fullName    String
  email       String              @unique
  phoneNumber String
  countryCode String
  etaRecords  ETARecord[]
  cases       ImmigrationCase[]
  violations  Violation[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ETARecord {
  id           String     @id
  individualId String
  etaNumber    String     @unique
  expiresAt    DateTime

  individual   Individual @relation(fields: [individualId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([individualId])
  @@index([expiresAt])
}

model ImmigrationCase {
  id                String           @id
  individualId      String
  reason            String
  assignedOfficerId String
  status            CaseStatus       @default(OPEN)
  riskLevel         RiskLevel
  createdAt         DateTime
  updatedAt         DateTime         @updatedAt

  individual        Individual       @relation(fields: [individualId], references: [id], onDelete: Restrict)
  recommendations   Recommendation[]

  @@index([individualId])
  @@index([assignedOfficerId])
  @@index([status])
}

model Recommendation {
  id              String          @id
  caseId          String
  authorOfficerId String
  summary         String
  createdAt       DateTime

  immigrationCase ImmigrationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model Violation {
  id               String            @id
  individualId     String?
  type             ViolationType
  domain           ViolationDomain
  severity         ViolationSeverity
  description      String            @db.Text
  reportContext    Json?
  reportedByActorId String?
  status           ViolationStatus   @default(REPORTED)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  individual       Individual?       @relation(fields: [individualId], references: [id], onDelete: SetNull)

  @@index([individualId])
  @@index([type])
  @@index([domain])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}
